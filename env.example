# ================================================================
# DevLearn API — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ================================================================

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devlearn
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# CORS (use specific origin in production, e.g. https://devlearn.io)
CORS_ORIGIN=*
