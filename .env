# ================================================================
# DevLearn API — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ================================================================

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devlearn
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# JWT
JWT_SECRET=devlearn_super_secret_key_123456789
JWT_EXPIRES_IN=7d

# CORS (use specific origin in production, e.g. https://devlearn.io)
CORS_ORIGIN=*
